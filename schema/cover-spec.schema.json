{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vidiomtm/coverforge/cover-spec.schema.json",
  "title": "CoverSpec",
  "description": "Renderer-agnostic cover specification. The sole contract between any model that analyses an episode and any engine that renders a cover. v1.0.",
  "type": "object",
  "required": ["version", "title", "characters"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version. Producers MUST emit \"1.0\"."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Display title for the cover."
    },
    "genre": {
      "type": "string",
      "maxLength": 80,
      "description": "Free-form genre tag shown under the title. Optional."
    },
    "mood": {
      "$ref": "#/$defs/Mood",
      "description": "World-level look. Optional; engine defaults when absent."
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/Character" }
    },
    "source": {
      "$ref": "#/$defs/Source",
      "description": "Provenance metadata. Optional, informational only."
    }
  },
  "$defs": {
    "Mood": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "palette": {
          "enum": [
            "noir-thriller",
            "neon-cyber",
            "sonnen-komoedie",
            "pastell-indie",
            "waldschatten",
            "blut-sonnenuntergang",
            "royal-prestige",
            "eis-stahl"
          ]
        },
        "sceneElement": {
          "enum": ["none", "skyline", "mountains", "stars", "clouds", "confetti"]
        },
        "typography": {
          "enum": ["blockbuster", "prestige", "scifi", "arthouse"]
        }
      }
    },
    "Character": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gender": { "enum": ["male", "female"] },
        "age": { "enum": ["child", "adult", "elderly"] },
        "body": { "enum": ["thin", "normal", "muscular", "stout"] },
        "hairColor": {
          "enum": ["blond", "brown", "red", "black", "grey"]
        },
        "hairStyle": {
          "enum": [
            "bald",
            "short",
            "mohawk",
            "long",
            "ponytail",
            "bun",
            "afro",
            "braids"
          ]
        },
        "eyeColor": { "enum": ["brown", "blue", "green"] },
        "skinTone": {
          "enum": ["light", "medium", "tan", "deep"]
        },
        "accessory": {
          "enum": [
            "none",
            "glasses",
            "sunglasses",
            "hat",
            "beanie",
            "beard"
          ]
        },
        "expression": {
          "enum": ["neutral", "smile", "serious", "surprised", "wink"]
        },
        "clothingStyle": {
          "enum": ["tshirt", "hoodie", "jacket", "dress", "sweater", "collared"]
        },
        "clothingPattern": {
          "enum": ["solid", "stripes", "dots", "emblem"]
        },
        "prop": {
          "enum": [
            "none",
            "book",
            "phone",
            "guitar",
            "coffee",
            "headphones",
            "pen",
            "umbrella",
            "camera",
            "speech"
          ]
        }
      }
    },
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subtitleEpisodeCount": {
          "type": "integer",
          "minimum": 0
        },
        "modelId": { "type": "string", "maxLength": 80 }
      }
    }
  }
}
